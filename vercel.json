{
  "version": 2,
  "functions": {
    "public/index.php": {
      "runtime": "vercel-php@0.7.3"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/public/index.php"
    },
    {
      "source": "/((?!.*\\.(?:css|js|mjs|map|png|jpg|jpeg|gif|svg|ico|webp|avif|woff|woff2|ttf|eot|txt|xml|json|pdf)$).*)",
      "destination": "/public/index.php"
    }
  ]
}
