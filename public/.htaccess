<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # Handle Authorization Header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Normalize duplicate slashes in URL path internally (no redirect)
    RewriteCond %{REQUEST_URI} ^(.*)//+(.*)$
    RewriteRule .* %1/%2 [N]

    # Redirect Trailing Slashes If Not A Folder...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} !^/+api/ [NC]
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=308]

    # Send Requests To Front Controller...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>

<IfModule mod_headers.c>
    SetEnvIfNoCase Request_URI "^/+api/" IS_API_REQUEST=1
    SetEnvIfNoCase Request_URI "^/+auth/(check|line-login|login|register)" IS_API_REQUEST=1

    # Some environments force text/html; normalize API responses to JSON
    Header always set Content-Type "application/json; charset=UTF-8" env=IS_API_REQUEST
</IfModule>
